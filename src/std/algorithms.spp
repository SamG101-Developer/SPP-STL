use std::annotations::abstract_method
use std::annotations::public
use std::boolean::Bool
use std::function::FunRef
use std::void::Void

!public
cls Sortable[T] { }

sup [T] Sortable[T] {
    !public
    !abstract_method
    fun sort(&mut self) -> Void { }

    !public
    !abstract_method
    fun sort_by(&mut self, compare: FunRef[(T, T), Bool]) -> Void { }
}
