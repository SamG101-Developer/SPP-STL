use std::annotations::public
use std::annotations::compiler_builtin
use std::llvm::inline
use std::boolean::Bool
use std::string_view::StrView
use std::void::Void

!public
!inline
!compiler_builtin
fun abort(msg: StrView = "") -> ! { }

!public
!inline
fun abort_if(condition: Bool, msg: StrView = "") -> Void {
    case condition { abort(msg) }
}
