use std::annotations::intrinsic
use std::annotations::public
use std::llvm::inline
use std::boolean::Bool
use std::string_view::StrView
use std::void::Void

!public
!inline
!intrinsic(name="std.abort.abort")
fun abort(msg: StrView = "") -> ! { }

!public
!inline
fun abort_if(condition: Bool, msg: StrView = "") -> Void {
    case condition { abort(msg) }
}
