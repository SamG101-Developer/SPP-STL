!public
!versioned(base="1.0.0", new="1.0.0")
cls Pass[T] {
    # The `Pass` class represents a successful result value. It is a generic class that can hold a value of any type
    # `T`. The `Pass` class is used in conjunction with the `Fail` class to represent result values, where `Pass`
    # indicates that an operation succeeded with a value, and `Fail` indicates that an operation failed with an error.
    # @type T: The type of the value contained in the `Pass` instance. This can be any type, and is specified when
    # creating a `Pass` instance.
    # @let val: The value contained in the `Pass` instance. This is the actual value that is present, and can be
    # accessed using the `unwrap` method. The value is of type `T`, and is specified when creating a `Pass` instance.

    !public val: T
}

!public
!versioned(base="1.0.0", new="1.0.0")
cls Fail[E] {
    # The `Fail` class represents a failed result value. It is a generic class that can hold an error of any type `E`.
    # The `Fail` class is used in conjunction with the `Pass` class to represent result values, where `Fail` indicates
    # that an operation failed with an error, and `Pass` indicates that an operation succeeded with a value.
    # @type E: The type of the error contained in the `Fail` instance. This can be any type, and is specified when
    # creating a `Fail` instance.
    # @let err: The error contained in the `Fail` instance. This is the actual error that occurred, and can be accessed
    # using the `unwrap_err` method. The error is of type `E`, and is specified when creating a `Fail` instance.

    !public err: E
}

!public
type Res[T, E] = Pass[T] or Fail[E]

sup [T: Copy, E: Copy] Res[T, E] ext Copy {
    # If the internal types of this result are both copy, then the result itself is also copy, as copying a result just
    # involves copying the internal value if it is Pass, or copying the internal error if it is Fail.
}

sup [T, E] Res[T, E] {
    # Multiple methods are provided for the `Res` type to allow for convenient manipulation and querying of result
    # values. These methods include checking if the result is `Pass` or `Fail`, applying predicates to the value or
    # error inside, chaining together multiple result computations, transforming the value or error inside the result,
    # and converting between result and optional types.

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun is_pass(&self) -> Bool {
        # The `is_pass` method checks if the result is in the `Pass` state. It returns `true` if the result is `Pass`,
        # and `false` if it is `Fail`. This is a wrapper around pattern matching.
        # @ret: Returns `true` if the result is `Pass`, and `false` if it is `Fail`.

        # Simple pattern match.
        ret self@ is Pass[T](..)
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun is_fail(&self) -> Bool {
        # The `is_fail` method checks if the result is in the `Fail` state. It returns `true` if the result is `Fail`,
        # and `false` if it is `Pass`. This is a wrapper around pattern matching.
        # @ret: Returns `true` if the result is `Fail`, and `false` if it is `Pass`.

        # Simple pattern match.
        ret self@ is Fail[E](..)
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun is_pass_and[F: FunMov[(T,), Bool]](self, pred: F) -> Bool {
        # The `is_pass_and` method checks if the result contains a value, and if so, applies the predicate to that
        # value. If the result is `Fail`, or if the predicate returns false, then `is_pass_and` returns `false`. If the
        # result contains a value and the predicate returns true, then `is_pass_and` returns `true`. This is a
        # convenient method for checking if a result contains a value that satisfies a certain condition, without having
        # to first check if the result is `Pass` and then apply the predicate separately.
        #
        # Example usage:
        # ```
        # let res = Pass(val=5)
        # let is_even = res.is_pass_and(|x| x % 2 == 0)
        # ```
        #
        # @let pred: The predicate function that is applied to the value inside the result if it is `Pass`. This
        # function is called with the value of type `T` if the result is `Pass`, and should return `true` if the value
        # satisfies the condition, or `false` otherwise.
        # @ret: Returns `true` if the result is `Pass` and the predicate returns `true` for the value inside, otherwise
        # returns `false`.

        # Pattern match and test against the predicate.
        ret case self of {
            is Pass[T](val) { pred(val) }
            is Fail[E](..) { false }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun is_fail_and[F: FunMov[(E,), Bool]](self, pred: F) -> Bool {
        # The `is_fail_and` method checks if the result contains an error, and if so, applies the predicate to that
        # error. If the result is `Pass`, or if the predicate returns false, then `is_fail_and` returns `false`. If the
        # result contains an error and the predicate returns true, then `is_fail_and` returns `true`. This is a
        # convenient method for checking if a result contains an error that satisfies a certain condition, without
        # having to first check if the result is `Fail` and then apply the predicate separately.
        #
        # Example usage:
        # ```
        # let res = Fail(err="error")
        # let is_long_error = res.is_fail_and(|e| e.len() > 5)
        # ```
        #
        # @let pred: The predicate function that is applied to the error inside the result if it is `Fail`. This
        # function is called with the error of type `E` if the result is `Fail`, and should return `true` if the error
        # satisfies the condition, or `false` otherwise.
        # @ret: Returns `true` if the result is `Fail` and the predicate returns `true` for the error inside, otherwise
        # returns `false`.

        # Pattern match and test against the predicate.
        ret case self of {
            is Fail[E](err) { pred(err) }
            is Pass[T](..) { false }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun is_fail_or[F: FunMov[(T,), Bool]](self, pred: F) -> Bool {
        # The `is_fail_or` method checks if the result is `Fail`, or if it is `Pass` and the predicate returns true for
        # the value inside. If the result is `Fail`, then `is_fail_or` returns `true`. If the result is `Pass` and the
        # predicate returns true for the value inside, then `is_fail_or` returns `true`. If the result is `Pass` and the
        # predicate returns false for the value inside, then `is_fail_or` returns `false`. This is a convenient method
        # for checking if a result is either `Fail` or contains a value that satisfies a certain condition, without
        # having to first check if the result is `Fail` and then apply the predicate separately.
        #
        # Example usage:
        # ```
        # let res = Pass(val=5)
        # let is_fail_or_even = res.is_fail_or(|x| x % 2 == 0)
        # ```
        #
        # @let pred: The predicate function that is applied to the value inside the result if it is `Pass`. This
        # function is called with the value of type `T` if the result is `Pass`, and should return `true` if the value
        # satisfies the condition, or `false` otherwise.
        # @ret: Returns `true` if the result is `Fail`, or if it is `Pass` and the predicate returns `true` for the
        # value inside, otherwise returns `false`.

        # Pattern match and test against the predicate.
        ret case self of {
            is Pass[T](val) { pred(val) }
            is Fail[E](..) { true }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun and_[U](self, that: Res[U, E]) -> Res[U, E] {
        # The `and_` method checks if this result contains a value, and if so, returns the other result. If this result
        # is `Fail`, then `and_` returns `Fail` with the same error. This is a convenient method for chaining together
        # multiple result computations, where you want to propagate `Fail` if any of the computations fail, but
        # otherwise return the result of the last computation.
        # @type U: The type of the value contained in the other result. This can be different from the type of the value
        # in this result.
        # @let that: The other result that is returned if this result is `Pass`. If this result is `Fail`, then `that`
        # is not evaluated, and `Fail` is returned with the same error instead.
        # @ret: Returns `that` if this result is `Pass`, otherwise returns `Fail` with the same error.

        # Pattern match and return the other result if this is
        # `Pass`, otherwise return `Fail` with the same error.
        ret case self of {
            is Pass[T](..) { that }
            is Fail[E](err) { Fail(err) }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun and_then[U, F: FunMov[(T,), Res[U, E]]](self, pred: F) -> Res[U, E] {
        # The `and_then` method checks if this result contains a value, and if so, applies the predicate to that value
        # and returns the result. If this result is `Fail`, then `and_then` returns `Fail` with the same error. This is
        # a convenient method for chaining together multiple result computations, where you want to propagate `Fail` if
        # any of the computations fail, but otherwise return the result of the last computation.
        # @type U: The type of the value contained in the result returned by the predicate. This can be different from
        # the type of the value in this result.
        # @let pred: The predicate function that is applied to the value inside the result if it is `Pass`. This
        # function is called with the value of type `T` if the result is `Pass`, and should return a `Res[U, E]` that is
        # the result of the computation. If the result is `Fail`, then `pred` is not evaluated, and `Fail` is returned
        # with the same error instead.
        # @ret: Returns the result of `pred` if this result is `Pass`, otherwise returns `Fail` with the same error.

        # Pattern match and apply the predicate to the value if
        # this is `Pass`, otherwise return `Fail` with the same error.
        ret case self of {
            is Pass[T](val) { pred(val) }
            is Fail[E](err) { Fail(err) }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun ior_[E](self, that: Res[T, E]) -> Res[T, E] {
        # The `ior_` method checks if this result contains a value, and if so, returns this result. If this result is
        # `Fail`, then `ior_` returns the other result. This is a convenient method for chaining together multiple
        # result computations, where you want to return the first `Pass` value if there is one, but otherwise return the
        # other result if this result failed.
        # @type E: The type of the error contained in the other result. This can be different from the type of the error
        # in this result.
        # @let that: The other result that is returned if this result is `Fail`. If this result is `Pass`, then `that`
        # is not evaluated, and this result is returned wrapped in `Pass` instead.
        # @ret: Returns this result wrapped in `Pass` if it is `Pass`, otherwise returns `that`.

        # Pattern match and return this result wrapped in `Pass` if it
        # is `Pass`, otherwise return the other result.
        ret case self of {
            is Pass[T](val) { Pass(val) }
            is Fail[E](..) { that }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun ior_else[F: FunMov[(E,), Res[T, F]]](self, pred: F) -> Res[T, E] {
        # The `ior_else` method checks if this result contains a value, and if so, returns this result. If this result
        # is `Fail`, then `ior_else` returns the result of invoking the provided predicate on the moved internally
        # wrapped error. This is a convenient method for chaining together multiple result computations, where you want
        # to return the first `Pass` value if there is one, but otherwise recover from the error by applying the
        # predicate to produce a new result.
        # @type F: The type of the error contained in the result returned by the predicate. This can be different from
        # the type of the error in this result.
        # @let pred: A function that is invoked with the error value if this result is `Fail`. If this result is `Pass`,
        # then `pred` is not evaluated, and this result is returned wrapped in `Pass` instead.
        # @ret: Returns this result wrapped in `Pass` if it is `Pass`, otherwise returns the result of invoking
        # `pred(err)`.

        # Pattern match and return this result wrapped in `Pass` if it
        # is `Pass`, otherwise return the result of invoking the
        # provided predicate on the error.
        ret case self of {
            is Pass[T](val) { Pass(val) }
            is Fail[E](err) { pred(err) }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun map[U, F: FunMov[(T,), U]](self, pred: F) -> Res[U, E] {
        # The `map` method checks if this result contains a value, and if so, applies the predicate to that value and
        # returns the result wrapped in `Pass`. If this result is `Fail`, then `map` returns `Fail` with the same error.
        # This is a convenient method for transforming the value inside a result based on a certain function, without
        # having to first check if the result is `Pass` and then apply the function separately.
        # @type U: The type of the value contained in the result returned by the predicate. This can be different from
        # the type of the value in this result.
        # @let pred: The function that is applied to the value inside the result if it is `Pass`. This function is
        # called with the value of type `T` if the result is `Pass`, and should return a value of type `U` that is the
        # result of the transformation. If the result is `Fail`, then `pred` is not evaluated, and `Fail` is returned
        # with the same error instead.
        # @ret: Returns the result of `pred` wrapped in `Pass` if this result is `Pass`, otherwise returns `Fail` with
        # the same error.

        # Pattern match and apply the predicate to the value if
        # this is `Pass`, otherwise return `Fail` with the same error.
        ret case self of {
            is Pass[T](val) { Pass(val=pred(val)) }
            is Fail[E](err) { Fail(err) }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun map_err[F: FunMov[(E,), E2]](self, pred: F) -> Res[T, E2] {
        # The `map_err` method checks if this result contains an error, and if so, applies the predicate to that error
        # and returns the result wrapped in `Fail`. If this result is `Pass`, then `map_err` returns `Pass` unchanged.
        # This is a convenient method for transforming the error inside a result based on a certain function, without
