    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun zip[U](self, that: Res[U, E]) -> Res[(T, U), E] {
        # The `zip` method combines this result with another result, returning a new result that contains a tuple of the
        # values inside both results if they are both `Pass`. If either result is `Fail`, then `zip` returns the first
        # `Fail` encountered. This is a convenient method for combining two result values into a single result value,
        # where the result is `Pass` only if both inputs are `Pass`.
        # @type U: The type of the value contained in the other result. This can be different from the type of the value
        # in this result.
        # @let that: The other result that is combined with this result. If both results are `Pass`, then the result is
        # a new result containing a tuple of the values inside both results. If either result is `Fail`, then the first
        # `Fail` is returned.
        # @ret: Returns a new result containing a tuple of the values inside both results if they are both `Pass`,
        # otherwise returns the first `Fail` encountered.

        # Pattern match on both results and return a new result
        # containing a tuple of the values if they are both `Pass`,
        # otherwise return the first `Fail` encountered.
        ret case (self, that) of {
            is (Pass[T](val as val1), Pass[U](val as val2)) { Pass(val=(val1, val2)) }
            is (Pass[T](..),          Fail[E](err))         { Fail(err) }
            is (Fail[E](err),         ..)                   { Fail(err) }
        }
    }
}

sup [T, E] Res[T, E] ext Try[Pass[T], Fail[E], T] {
    # In order to make the Res type compatible with the "?" operator, we need to tell the compiler how to check if a
    # result type is in the value state or not, so it knows whether to propagate the error state or not. In this case,
    # only if the result is in the Pass state do we have a value, so we check for that.

    !versioned(base="1.0.0", new="1.0.0")
    fun op_is_value(&self) -> Bool {
        # The `op_is_value` method checks if this result is in the value state, which means it contains a value wrapped
        # in `Pass`, so we pattern match on the result and return `true` if it is `Pass`, otherwise return `false`.
        # @ret: Returns `true` if this result is in the value state (i.e., it is `Pass`), otherwise returns `false`.

        # Pattern match and return `true` if this is `Pass`, otherwise
        # return `false`.
        ret self@ is Pass[T](..)
    }

    !versioned(base="1.0.0", new="1.0.0")
    fun op_as_value(self) -> T {
        # The `op_as_value` method extracts the value from this result if it is in the value state. This method is used
        # by the "?" operator to extract the value from a result when it is in the value state, and to propagate the
        # error state if it is not. This method aborts if called on a `Fail` value, though in practice the `?` operator
        # checks the state with `op_is_value` before calling this method.
        # @ret: Returns the value inside the result if it is in the value state (i.e., it is `Pass`).

        # Pattern match and return the value if this is `Pass`,
        # otherwise abort the program with an error message.
        ret case self of {
            is Pass[T](val) { val }
            else { std::abort::abort("called `op_as_value` on a `Fail` value") }
        }
    }
}

sup [T: Eq, E: Eq] Res[T, E] ext Eq {
    # Additional methods for result types where both the value and error types implement the `Eq` trait, which allows
    # for equality comparisons between results.

    !versioned(base="1.0.0", new="1.0.0")
    fun eq(&self, that: &Self) -> Bool {
        # The `eq` method checks if this result is equal to another result. Two results are considered equal if they are
        # both `Pass` and the values inside are equal, or if they are both `Fail` and the errors inside are equal.
        # @let that: The other result that is compared with this result.
        # @ret: Returns `true` if this result is equal to `that`, otherwise returns `false`.

        # Pattern match on both results and return `true` if they are
        # both `Pass` with equal values, or both `Fail` with equal
        # errors.
        ret case (self@, that@) of {
            is (Pass[T](val as a), Pass[T](val as b)) { a == b }
            is (Fail[E](err as a), Fail[E](err as b)) { a == b }
            else { false }
        }
    }

    !versioned(base="1.0.0", new="1.0.0")
    fun ne(&self, that: &Self) -> Bool {
        # The `ne` method checks if this result is not equal to another result. Two results are considered not equal if
        # they are not both `Pass` with equal values, or not both `Fail` with equal errors.
        # @let that: The other result that is compared with this result.
        # @ret: Returns `true` if this result is not equal to `that`, otherwise returns `false`.

        # Pattern match on both results and return `true` if they are
        # not both `Pass` with equal values, or not both `Fail` with
        # equal errors.
        ret case (self@, that@) of {
            is (Pass[T](val as a), Pass[T](val as b)) { a != b }
            is (Fail[E](err as a), Fail[E](err as b)) { a != b }
            else { true }
        }
    }
}
