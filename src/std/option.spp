        # @ret: Returns the result of `pred` if this optional is `Some`, otherwise returns `None`.

        # Pattern match and apply the predicate to the value if
        # this is `Some`, otherwise return `None`.
        ret case self of {
            is Some[T](val) { pred(val) }
            is None() { None }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun ior_(self, that: Opt[T]) -> Opt[T] {
        # The `ior_` method checks if this optional contains a value, and if so, returns this optional. If this optional
        # is `None`, then `ior_` returns the other optional. This is a convenient method for chaining together multiple
        # optional computations, where you want to return the first `Some` value if there is one, but otherwise return
        # `None` if all computations return `None`.
        # @let that: The other optional that is returned if this optional is `None`. If this optional is `Some`, then
        # `that` is not evaluated, and this optional is returned instead.
        # @ret: Returns this optional if it is `Some`, otherwise returns `that`.

        # Pattern match and return this optional if it is `Some`,
        # otherwise return the other optional.
        ret case self of {
            is Some[T](..) { self }
            is None() { that }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun ior_else(self, that: FunMov[(), Opt[T]]) -> Opt[T] {
        # The `ior_else` method checks if this optional contains a value, and if so, returns this optional. If this
        # optional is `None`, then `ior_else` returns the result of invoking the provided function to get the other
        # optional. This is a convenient method for chaining together multiple optional computations, where you want to
        # return the first `Some` value if there is one, but otherwise return the result of a computation that produces
        # an optional if all computations return `None`.
        # @let that: A function that is invoked to get the other optional if this optional is `None`. If this optional
        # is `Some`, then `that` is not evaluated, and this optional is returned instead.
        # @ret: Returns this optional if it is `Some`, otherwise returns the result of invoking `that()`.

        # Pattern match and return this optional if it is `Some`,
