        # @let val: The new value that is set inside the optional. If this optional is `Some`, then the old value is
        # returned wrapped in `Some`, otherwise `None` is returned.
        # @ret: Returns the old value wrapped in `Some` if this optional was `Some`, otherwise returns `None`.

        # Pattern match and replace the value if this is `Some`,
        # otherwise set the value to `Some(val)` and return `None`.
        # todo: test if this errors when missing "mut" on "val" in the pattern match.
        ret case self of {
            is Some[T](mut val as old_val) {
                std::mem::ops::swap(&mut old_val, &mut val)
                Some(val=old_val)
            }
            else {
                self@ = Some(val)
                None
            }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun take(&mut self) -> Opt[T] {
        # The `take` method takes the value out of this optional, leaving a `None` in its place. If this optional is
        # `Some`, then `take` returns the value wrapped in `Some`, and sets this optional to `None`.
        # @ret: Returns the value inside the optional wrapped in `Some` if this optional is `Some`, otherwise returns
        # `None`.

        # Pattern match and take the value if this is `Some`, otherwise
        # return `None`.
        ret case self of {
            is Some[T](..) { self }
            else { None }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun take_if(&mut self, pred: FunMov[(&T,), Bool]) -> Opt[T] {
        # The `take_if` method takes the value out of this optional if it satisfies the provided predicate, leaving a
        # `None` in its place. If this optional is `Some` and the predicate returns true for the value inside, then
        # `take_if` returns the value wrapped in `Some`, and sets this optional to `None`. If this optional is `None`,
        # or if the predicate returns false for the value inside, then `take_if` returns `None`.
        # @let pred:
        # @ret:

        # Pattern match and take the value if this is `Some` and
        # the predicate returns true, otherwise return `None`.
        ret case self of {
            is Some[T](val) { case pred(&val) { self } else { None } }
            else { None }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun zip[U](self, that: Opt[U]) -> Opt[(T, U)] {
        # The `zip` method combines this optional with another optional, returning a new optional that contains a tuple
        # of the values inside both optionals if they are both `Some`. If either optional is `None`, then `zip` returns
        # `None`. This is a convenient method for combining two optional values into a single optional value, where the
        # result is `Some` only if both inputs are `Some`.
        # @type U: The type of the value contained in the other optional. This can be different from the type of the
        # value in this optional.
        # @let that: The other optional that is combined with this optional. If both optionals are `Some`, then the
        # result is a new optional containing a tuple of the values inside both optionals. If either optional is `None`,
        # then the result is `None`.
        # @ret: Returns a new optional containing a tuple of the values inside both optionals if they are both `Some`,
        # otherwise returns `None`.

        # Pattern match on both optionals and return a new optional
        # containing a tuple of the values if they are both `Some`,
        # otherwise return `None`.
        ret case (self, that) of {
            is (Some[T](val as val1), Some[U](val as val2)) { Some(val=(val1, val2)) }
            else { None }
        }
    }
}

sup [T] Opt[Opt[T]] {
    # Additional method for nested optional types.

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun flatten(self) -> Opt[T] {
        # The `flatten` method takes an optional that contains another optional, and returns a new optional that
        # contains the value inside the inner optional if it is `Some`. If the outer optional is `None`, or if the inner
        # optional is `None`, then `flatten` returns `None`. This method only collapses one level of nested optionals,
        # so if the inner optional is itself an optional that contains another optional, `faltten` will need to be
        # chained.
        # @ret: Returns a new optional containing the value inside the inner optional if it is `Some`, otherwise returns
        # `None`.

        # Pattern match and return the value inside the inner optional if
        # the outer optional is `Some`, otherwise return `None`.
        ret case self of {
            is Some[T](val) { val }
            else { None }
        }
    }
}

sup [T] Opt[T] ext Try[Some[T], None, T] {
    # In order to make the Opt type compatible with the "?" operator, we need to tell the compiler how to check if an
    # optional type is in the value state or not, so it knows whether to propagate the error state or not.

    !versioned(base="1.0.0", new="1.0.0")
    fun op_is_value(&self) -> Bool {
        # The `op_is_value` method checks if this optional is in the value state, which means it contains a value
        # wrapped in `Some`, so we pattern match on the optional and return `true` if it is `Some`, otherwise return
        # `false`.
        # @ret: Returns `true` if this optional is in the value state (i.e., it is `Some`), otherwise returns `false`.

        # Pattern match and return `true` if this is `Some`, otherwise
        # return `false`.
        ret self@ is Some[T](..)
    }

    !versioned(base="1.0.0", new="1.0.0")
    fun op_as_value(self) -> T {
        # The `op_as_value` method extracts the value from this optional if it is in the value state. This method is
        # used by the "?" operator to extract the value from an optional when it is in the value state, and to propagate
        # the error state if it is not. This will never fail, because the `?` operator checks the state with
        # `op_is_value` before calling this method, so it is guaranteed that this method is only called when the
        # optional is in the value state.
        # @ret: Returns the value inside the optional if it is in the value state (i.e., it is `Some`).

        # Unwrap the value from the optional, which is guaranteed to be
        # in the value state
        ret self.unwrap()
    }
}

sup [T, U] Opt[(T, U)] {
    # Additional method for optional types that contain a tuple of two values.

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun unzip(self) -> (Opt[T], Opt[U]) {
        # The `unzip` method takes an optional that contains a tuple of two values, and returns a tuple of two
        # optionals, where the first optional contains the first value of the tuple if it is `Some`, and the second
        # optional contains the second value of the tuple if it is `Some`. If the outer optional is `None`, then both
        # optionals in the returned tuple are `None`.
        # @ret: Returns a tuple of two optionals, taking each value from the tuple inside the optional if it is `Some`,
        # otherwise returns a tuple of two `None` optionals.

        # Pattern match and return a tuple of two optionals, taking
        # each value from the tuple inside the optional.
        ret case self of {
            is Some[(T, U)](val=(val1, val2)) { (Some(val=val1), Some(val=val2)) }
            is None() { (None, None) }
        }
    }
}

sup [T: Eq] Opt[T] ext Eq {
    # Additional methods for optional types that contain values that implement the `Eq` trait, which allows for equality
    # comparisons between optionals.

    !versioned(base="1.0.0", new="1.0.0")
    fun eq(&self, that: &Self) -> Bool {
        # The `eq` method checks if this optional is equal to another optional. Two optionals are considered equal if
        # they are both `None`, or if they are both `Some` and the values inside are equal.
        # @let that: The other optional that is compared with this optional.
        # @ret: Returns `true` if this optional is equal to `that`, otherwise returns `false`.

        # Pattern match on both optionals and return `true` if they are
        # both `None`, or if they are both `Some` and the values inside
        # are equal.
        ret case (self@, that@) of {
            is (Some[T](val as a), Some[T](val as b)) { a == b }
            is (None(), None()) { true }
            else { false }
        }
    }

    !versioned(base="1.0.0", new="1.0.0")
    fun ne(&self, that: &Self) -> Bool {
        # The `ne` method checks if this optional is not equal to another optional. Two optionals are considered not
        # equal if they are not both `None`, or if they are both `Some` and the values inside are not equal.
        # @let that: The other optional that is compared with this optional.
        # @ret: Returns `true` if this optional is not equal to `that`, otherwise returns `false`.

        # Pattern match on both optionals and return `true` if they are
        # not both `None`, or if they are both `Some` and the values inside
        # are not equal.
        ret case (self@, that@) of {
            is (Some[T](val as a), Some[T](val as b)) { a != b }
            is (None(), None()) { false }
            else { true }
        }
    }
}
