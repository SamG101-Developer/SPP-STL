!public
!versioned(base="1.0.0", new="1.0.0")
cls Some[T] {
    # The `Some` class represents an optional value that is present. It is a generic class that can hold a value of any
    # type `T`. The `Some` class is used in conjunction with the `None` class to represent optional values, where `Some`
    # indicates that a value is present, and `None` indicates that no value is present.
    # @type T: The type of the value contained in the `Some` instance. This can be any type, and is specified when
    # creating a `Some` instance.
    # @let val: The value contained in the `Some` instance. This is the actual value that is present, and can be
    # accessed using the `unwrap` method. The value is of type `T`, and is specified when creating a `Some` instance.

    !public val: T
}

!public !zero_type
!versioned(base="1.0.0", new="1.0.0")
cls None {
    # The `None` class represents an optional value that is not present. It is a zero-sized type that does not hold any
    # value, allowing ti to be specified as the sineton `None` rather than needing `None()` everywhere.
}

!public
type Opt[T] = Some[T] or None

sup [T: Copy] Opt[T] ext Copy {
    # If the internal type of this optional is copy, then the optional itself is also copy, as copying an optional just
    # involves copying the internal value if it is Some, and doing nothing if it is None.
}

sup [T] Opt[T] {
    # Multiple methods are provided for the `Opt` type to allow for convenient manipulation and querying of optional
    # values. These methods include checking if the optional is `Some` or `None`, applying predicates to the value
    # inside, chaining together multiple optional computations, filtering the value based on a condition, and
    # transforming the value inside the optional.

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun is_some(&self) -> Bool {
        # The `is_some` method checks if the optional is in the `Some` state. It returns `true` if the optional is
        # `Some`, and `false` if it is `None`. This is a wrapper around pattern matching.
        # @ret: Returns `true` if the optional is `Some`, and `false` if it is `None`.

        # Simple pattern match.
        ret self@ is Some[T](..)
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun is_none(&self) -> Bool {
        # The `is_none` method checks if the optional is in the `None` state. It returns `true` if the optional is
        # `None`, and `false` if it is `Some`. This is a wrapper around pattern matching.
        # @ret: Returns `true` if the optional is `None`, and `false` if it is `Some`.

        # Simple pattern match.
        ret self@ is None()
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun is_some_and[P: FunMov[(T,), Bool]](self, pred: P) -> Bool {
        # The `is_some_and` method checks if the optional contains a value, and if so, applies the predicate to that
        # value. If the optional is `None`, or if the predicate returns false, then `is_some_and` returns `false`. If
        # the optional contains a value and the predicate returns true, then `is_some_and` returns `true`. This is a
        # convenient method for checking if an optional contains a value that satisfies a certain condition, without
        # having to first check if the optional is Some and then apply the predicate separately.
        #
        # Example usage:
        # ```
        # let opt = Some(val=5)
        # let is_even = opt.is_some_and(|x| x % 2 == 0)
        # ```
        #
        # @type P: The type of the predicate function. This must be a function that takes a single argument of type `T`
        # and returns a `Bool`.
        # @let pred: The predicate function that is applied to the value inside the optional if it is `Some`. This
        # function is called with the value of type `T` if the optional is `Some`, and should return `true` if the value
        # satisfies the condition, or `false` otherwise.
        # @ret: Returns `true` if the optional is `Some` and the predicate returns `true` for the value inside,
        # otherwise returns `false`.

        # Pattern match and test against the predicate.
        ret case self of {
            is Some[T](val) { pred(val) }
            is None() { false }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun is_none_or[P: FunMov[(T,), Bool]](self, pred: P) -> Bool {
        # The `is_none_or` method checks if the optional is `None`, or if it is `Some` and the predicate returns true
        # for the value inside. If the optional is `None`, then `is_none_or` returns `true`. If the optional is `Some`
        # and the predicate returns true for the value inside, then `is_none_or` returns `true`. If the optional is
        # `Some` and the predicate returns false for the value inside, then `is_none_or` returns `false`. This is a
        # convenient method for checking if an optional is either `None` or contains a value that satisfies a certain
        # condition, without having to first check if the optional is `None` and then apply the predicate separately.
        #
        # Example usage:
        # ```
        # let opt = Some(val=5)
        # let is_none_or_even = opt.is_none_or(|x| x % 2 == 0)
        # ```
        #
        # @type P: The type of the predicate function. This must be a function that takes a single argument of type `T`
        # and returns a `Bool`.
        # @let pred: The predicate function that is applied to the value inside the optional if it is `Some`. This
        # function is called with the value of type `T` if the optional is `Some`, and should return `true` if the value
        # satisfies the condition, or `false` otherwise.
        # @ret: Returns `true` if the optional is `None`, or if it is `Some` and the predicate returns `true` for the
        # value inside, otherwise returns `false`.

        # Pattern match and test against the predicate.
        ret case self of {
            is Some[T](val) { pred(val) }
            is None() { true }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun and_[U](self, that: Opt[U]) -> Opt[U] {
        # The `and_` method checks if this optional contains a value, and if so, returns the other optional. If this
        # optional is `None`, then `and_` returns `None`. This is a convenient method for chaining together multiple
        # optional computations, where you want to return `None` if any of the computations return `None`, but otherwise
        # return the result of the last computation.
        # @type U: The type of the value contained in the other optional. This can be different from the type of the
        # value in this optional.
        # @let that: The other optional that is returned if this optional is `Some`. If this optional is `None`, then
        # `that` is not evaluated, and `None` is returned instead.
        # @ret: Returns `that` if this optional is `Some`, otherwise returns `None`.

        # Pattern match and return the other optional if this is
        # `Some`, otherwise return `None`.
        ret case self of {
            is Some[T](..) { that }
            is None() { None }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun and_then[U, P: FunMov[(T,), Opt[U]]](self, pred: P) -> Opt[U] {
        # The `and_then` method checks if this optional contains a value, and if so, applies the predicate to that value
        # and returns the result. If this optional is `None`, then `and_then` returns `None`. This is a convenient
        # method for chaining together multiple optional computations, where you want to return `None` if any of the
        # computations return `None`, but otherwise return the result of the last computation.
        # @type U: The type of the value contained in the optional returned by the predicate. This can be different from
        # the type of the value in this optional.
        # @type P: The type of the predicate function. This must be a function that takes a single argument of type `T`
        # and returns an `Opt[U]`.
        # @let pred: The predicate function that is applied to the value inside the optional if it is `Some`. This
        # function is called with the value of type `T` if the optional is `Some`, and should return an `Opt[U]` that is
