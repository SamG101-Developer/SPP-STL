    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun map[U, F: FunMov[(T,), U]](self, func: F) -> Opt[U] {
        # The `map` method checks if this optional contains a value, and if so, applies the predicate to that value and
        # returns the result wrapped in `Some`. If this optional is `None`, then `map` returns `None`. This is a
