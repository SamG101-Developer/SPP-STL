        ret case self of {
            is Some[T](..) { self }
            is None() { that() }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun xor(self, that: Opt[T]) -> Opt[T] {
        # The `xor` method checks if exactly one of this optional and the other optional contains a value, and if so,
        # returns that value wrapped in `Some`. If both optionals are `None`, or if both optionals are `Some`, then
        # `xor` returns `None`. This is a convenient method for chaining together multiple optional computations, where
        # you want to return the value of the first `Some` if there is exactly one `Some`, but otherwise return `None`
        # if there are zero or more than one `Some` values.
        # @let that: The other optional that is compared with this optional. If exactly one of this optional and `that`
        # is `Some`, then the value of that `Some` is returned wrapped in `Some`. If both optionals are `None`, or if
        # both optionals are `Some`, then `None` is returned.
        # @ret: Returns the value of the `Some` optional wrapped in `Some` if exactly one of this optional and `that` is
        # `Some`, otherwise returns `None`.

        # Pattern match on both optionals and return the value of
        # the `Some` if exactly one is `Some`, otherwise return `None`.
        ret case (self, that) of {
            is (Some[T](val), None()) { Some(val) }
            is (None(), Some[T](val)) { Some(val) }
            else { None }
        }
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun filter[P: FunMov[(&T,), Bool]](self, pred: P) -> Opt[T] {
        # The `filter` method checks if this optional contains a value, and if so, applies the predicate to that value.
        # If this optional is `None`, then `filter` returns `None`. If this optional is `Some` and the predicate returns
        # true for the value inside, then `filter` returns this optional. If this optional is `Some` and the predicate
        # returns false for the value inside, then `filter` returns `None`. This is a convenient method for filtering
        # the value inside an optional based on a certain condition, without having to first check if the optional is
        # `Some` and then apply the predicate separately.
        # @type P: The type of the predicate function. This must be a function that takes a single argument of type `&T`
        # (a borrow to the value inside the optional) and returns a `Bool`.
        # @let pred: The predicate function that is applied to the value inside the optional if it is `Some`. This
        # function is called with a borrow of the value of type `T` if the optional is `Some`, and should return `true`
        # if the value satisfies the condition, or `false` otherwise. If the optional is `None`, then `pred` is not
        # evaluated, and `None` is returned instead.
        # @ret: Returns this optional if it is `Some` and the predicate returns `true` for the value inside, otherwise
        # returns `None`.

        # Pattern match and apply the predicate to a borrow of
        # the value if this is `Some`.
        ret case self of {
            is Some[T](val) { case pred(&val) { self } else { None } }
            is None() { None }
        }
