!intrinsic(name="std.arch2.mmx.mm_adds_pu8")
!always_inline
!asm(instruction="paddusb")
fun mm_adds_pu8(a: M64, b: M64) -> M64 {
    # Add packed unsigned 8-bit integers in a and b using saturation, and store the results in dst.
