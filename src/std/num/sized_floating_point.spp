!package
!versioned(base="1.0.0", new="1.0.0")
cls SizedFloatingPoint[cmp w: U32] {
    # The `SizedFloatingPoint` class represents a floating point type with a specific bit width. The `w` parameter is a
    # compile-time constant that specifies the number of bits used to represent the floating point value. This allows
    # for the creation of floating point types with different levels of precision, such as single precision (32 bits)
    # and double precision (64 bits). The `SizedFloatingPoint` class is a generic class that can be extended to create
    # specific sized floating point types, and it provides various methods for performing mathematical operations and
    # comparisons on floating point values of the specified size.
    # @cmp w: The number of bits used to represent the floating point value. This is a compile-time constant that
    # determines the precision of the floating point type. The provided values for `w` are: - `8`: Quarter precision
    # floating point (binary8) - `16`: Half precision floating point (binary16) - `32`: Single precision floating point
    # (binary32) - `64`: Double precision floating point (binary64) - `128`: Quadruple precision floating point
    # (binary128)
}

sup [cmp w: U32] SizedFloatingPoint[w] ext FloatingPoint {
    # The `SizedFloatingPoint` class extends the `FloatingPoint` class, which means that all sized floating point types
    # are also considered floating point types. This allows for the use of sized floating point types in contexts where
    # a floating point type is expected, such as in mathematical operations or generic functions that operate on
    # floating point types, where the size is not important, typically code in the `instrinsics` module. This also saves
    # on monomorphization costs.
}

sup [cmp this_w: U32, cmp that_w: U32]
SizedFloatingPoint[this_w] ext
From[SizedFloatingPoint[that_w]] {
    # Converting between floating point types of potentially different sizes.

    !versioned(base="1.0.0", new="1.0.0")
    fun from(that: SizedFloatingPoint[that_w]) -> Self {
        # The `from` method defines how to convert a floating point value of one size to another size. The conversion is
        # performed based on the relationship between the bit widths of the source and target types. The following three
        # cases are handled:
        # 1. If the target type has fewer bits than the source type (this_w < that_w), the conversion is done by
        # truncating the source value to fit into the smaller target type. This is typically done by discarding the
        # least significant bits of the source value, which may result in a loss of precision.
        # 2. If the target type has more bits than the source type (this_w > that_w), the conversion is done by
        # extending the source value to fit into the larger target type. This is typically done by adding additional
        # bits to the source value, which may involve zero-extending or sign-extending the value depending on whether it
        # is unsigned or signed.
        # 3. If the target type has the same number of bits as the source type (this_w == that_w), the conversion is
        # simply a copy of the value, as no change in precision is needed.
        # @let that: The floating point value of the source type that is being converted to the target type.
        # @ret: The converted floating point value of the target type, which may have a different precision than the
        # source value depending on the relationship between their bit widths.

        # If the source has more bits, truncate it.
        # If the source has fewer bits, extend it.
        ret case this_w of {
            < that_w { intrinsics::fptrunc[this_w](that) }
            > that_w { intrinsics::fpext[this_w](that) }
            else { intrinsics::bit_cast[Self](that) }
        }
    }
}

sup [cmp w: U32] SizedFloatingPoint[w] ext Eq {
    # Provide equality support to sized floating point numbers, allowing for comparison of two floating point values of
    # the same size for equality and inequality. For differing sizes, the `From` trait can be used to convert one of the
    # values to the same size as the other before performing the comparison.

    !versioned(base="1.0.0", new="1.0.0")
    cmp fun eq(&self, that: &Self) -> Bool {
        # The `eq` method defines how to compare two floating point values of the same size for equality. It uses the
        # `oeq` intrinsic function to perform the comparison, which checks if the two values are equal according to the
        # rules of floating point arithmetic.
        # @let that: A borrow to the floating point value that is being compared to the current value for equality.
        # @ret: `true` if the two floating point values are equal, and `false` otherwise.

        # Hook into equality intrinsic.
        ret intrinsics::oeq(self, that)
    }

    !versioned(base="1.0.0", new="1.0.0")
    cmp fun ne(&self, that: &Self) -> Bool {
        # The `ne` method defines how to compare two floating point values of the same size for inequality. It uses the
        # `one` intrinsic function to perform the comparison, which checks if the two values are not equal according to
        # the rules of floating point arithmetic.
        # @let that: A borrow to the floating point value that is being compared to the current value for inequality.
        # @ret: `true` if the two floating point values are not equal, and `false` otherwise.

        # Hook into inequality intrinsic.
        ret intrinsics::one(self, that)
    }
}

sup [cmp w: U32] SizedFloatingPoint[w] ext Ord {
    # Provide ordering support to sized floating point numbers, allowing for comparison of two floating point values of
    # the same size to determine their relative ordering. For differing sizes, the `From` trait can be used to convert
    # one of the values to the same size as the other before performing the comparison.

    !versioned(base="1.0.0", new="1.0.0")
    fun ord(&self, that: &Self) -> S32 {
        # The `ord` method defines how to compare two floating point values of the same size and determine their
        # ordering. It uses the `fcmp` intrinsic function to perform the comparison, which checks the relative ordering
        # of the two values according to the rules of floating point arithmetic.
        # @let that: A borrow to the floating point value that is being compared to the current value for ordering.
        # @ret: An `S32` value indicating the ordering of the two floating point values:
        # - A negative value indicates that the current value is less than the other value.
        # - Zero indicates that the two values are equal.
        # - A positive value indicates that the current value is greater than the other value.

        # Hook into comparison intrinsic.
        ret intrinsics::fcmp(self, that)
    }

    !versioned(base="1.0.0", new="1.0.0")
    cmp fun lt(&self, that: &Self) -> Bool {
        # The `lt` method defines how to compare two floating point values of the same size to determine if the current
        # value is less than the other value. It uses the `olt` intrinsic function to perform the comparison, which
        # checks if the current value is less than the other value according to the rules of floating point arithmetic.
        # @let that: A borrow to the floating point value that is being compared to the current value for ordering.
        # @ret: `true` if the current value is less than the other value, and `false` otherwise.

        # Hook into less-than intrinsic.
        ret intrinsics::olt(self, that)
    }

    !versioned(base="1.0.0", new="1.0.0")
    cmp fun le(&self, that: &Self) -> Bool {
        # The `le` method defines how to compare two floating point values of the same size to determine if the current
        # value is less than or equal to the other value. It uses the `ole` intrinsic function to perform the
        # comparison, which checks if the current value is less than or equal to the other value according to the rules
        # of floating point arithmetic.
        # @let that: A borrow to the floating point value that is being compared to the current value for ordering.
        # @ret: `true` if the current value is less than or equal to the other value, and `false` otherwise.

        # Hook into less-than-or-equal-to intrinsic.
        ret intrinsics::ole(self, that)
    }

    !versioned(base="1.0.0", new="1.0.0")
    cmp fun gt(&self, that: &Self) -> Bool {
        # The `gt` method defines how to compare two floating point values of the same size to determine if the current
        # value is greater than the other value. It uses the `ogt` intrinsic function to perform the comparison, which
        # checks if the current value is greater than the other value according to the rules of floating point
        # arithmetic.
        # @let that: A borrow to the floating point value that is being compared to the current value for ordering.
        # @ret: `true` if the current value is greater than the other value, and `false` otherwise.

        # Hook into greater-than intrinsic.
        ret intrinsics::ogt(self, that)
    }

    !versioned(base="1.0.0", new="1.0.0")
    cmp fun ge(&self, that: &Self) -> Bool {
        # The `ge` method defines how to compare two floating point values of the same size to determine if the current
        # value is greater than or equal to the other value. It uses the `oge` intrinsic function to perform the
        # comparison, which checks if the current value is greater than or equal to the other value according to the
        # rules of floating point arithmetic.
        # @let that: A borrow to the floating point value that is being compared to the current value for ordering.
        # @ret: `true` if the current value is greater than or equal to the other value, and `false` otherwise.

        # Hook into greater-than-or-equal-to intrinsic.
        ret intrinsics::oge(self, that)
    }
}

