    cmp fun trunc(self) -> Self {
        ret intrinsics::float_trunc(self)
    }
}

sup [cmp w: U32] SizedFloatingPoint[w] {
    !public !inline
    !versioned(base="1.0.0", new="1.0.0")
    fun sin(self) -> Self {
        ret intrinsics::float_sin(self)
    }

    !public !inline
    !versioned(base="1.0.0", new="1.0.0")
    fun cos(self) -> Self {
        ret intrinsics::float_cos(self)
    }

    !public !inline
    !versioned(base="1.0.0", new="1.0.0")
    fun tan(self) -> Self {
        ret intrinsics::float_tan(self)
    }

    !public !inline
    !versioned(base="1.0.0", new="1.0.0")
    fun asin(self) -> Self {
        ret intrinsics::float_asin(self)
    }

    !public !inline
    !versioned(base="1.0.0", new="1.0.0")
    fun acos(self) -> Self {
        ret intrinsics::float_acos(self)
    }

    !public !inline
    !versioned(base="1.0.0", new="1.0.0")
    fun atan(self) -> Self {
        ret intrinsics::float_atan(self)
    }

    !public !inline
    !versioned(base="1.0.0", new="1.0.0")
    fun atan2(self, other: Self) -> Self {
        ret intrinsics::float_atan2(self, other)
    }

    !public !inline
    !versioned(base="1.0.0", new="1.0.0")
    fun sinh(self) -> Self {
        ret intrinsics::float_sinh(self)
    }

    !public !inline
    !versioned(base="1.0.0", new="1.0.0")
    fun cosh(self) -> Self {
        ret intrinsics::float_cosh(self)
    }

    !public !inline
    !versioned(base="1.0.0", new="1.0.0")
    fun tanh(self) -> Self {
        ret intrinsics::float_tanh(self)
    }

    !public !inline
    !versioned(base="1.0.0", new="1.0.0")
    fun asinh(self) -> Opt[Self] {
        # ln(x + sqrt(x^2 + 1)) Todo: Unchecked version? Or no check => NaN?
        ret (self + (self * self + Self::one()).sqrt()).ln()
    }

    !public !inline
    !versioned(base="1.0.0", new="1.0.0")
    fun acosh(self) -> Opt[Self] {
        # ln(x + sqrt(x^2 - 1)), domain x >= 1 Todo: Unchecked version? Or no check => NaN?
        case self < Self::one() { ret None }
        ret Some(val=(self + (self * self - Self::one()).sqrt()).ln())
    }

    !public !inline
    !versioned(base="1.0.0", new="1.0.0")
    fun atanh(self) -> Opt[Self] {
        # 0.5 * ln((1 + x) / (1 - x)),  domain |x| < 1 Todo: Unchecked version? Or no check => NaN?
        case self <= Self::neg_one() or self >= Self::one() { ret None }
        let one = Self::one()
        ret Some(val=((one + self) / (one - self)).ln() * Self::from(0.5_f64))
    }
}

