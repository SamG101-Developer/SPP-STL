sup [cmp w: U32, cmp signed: Bool] SizedInteger[w, signed] ext Eq {
    cmp fun eq(&self, that: &Self) -> Bool {
        ret intrinsics::eq(self, that)
    }

    cmp fun ne(&self, that: &Self) -> Bool {
        ret intrinsics::ne(self, that)
    }
}

sup [cmp w: U32, cmp signed: Bool] SizedInteger[w, signed] ext BitAnd {
    cmp fun bit_and(self, that: Self) -> Self {
        ret intrinsics::bit_and(self, that)
    }
}

sup [cmp w: U32, cmp signed: Bool] SizedInteger[w, signed] ext BitAndAssign {
    cmp fun bit_and_assign(&mut self, that: Self) -> Void {
        intrinsics::bit_and_assign(self, that)
    }
}

