sup [cmp w: U32, cmp signed: Bool] SizedInteger[w, signed] ext From[Bool] {
    !always_inline
    !versioned(base="1.0.0", new="1.0.0")
    fun from(that: Bool) -> Self {
        # The `from` method defines how to convert a boolean value to an unsigned integer type of potentially different
        # sizes. The conversion is performed by mapping the boolean value to an unsigned integer representation. The
        # following mapping is used:
        # - If the boolean value is `true`, it is converted to the unsigned integer value `1`.
        # - If the boolean value is `false`, it is converted to the unsigned integer value `0`.
        # This conversion is useful when a boolean value needs to be represented as an unsigned integer for various
        # purposes, such as bit manipulation or arithmetic operations.
        # @let that: The boolean value that is being converted to the unsigned integer type.
        # @ret: The converted unsigned integer value of the target type, which will be either `1` for `true` or `0` for
        # `false`.

        ret case that { Self::one() } else { Self::zero() }
    }
}

sup [cmp w: U32, cmp signed: Bool] SizedInteger[w, signed] {
    !public
    !inline
    fun leading_zeros(self) -> U32 {
        ret intrinsics::ctlz(self)
    }

    !public
    !inline
    fun is_even(self) -> Bool {
        ret self & Self::one() == Self::zero()
    }

    !public
    !inline
    fun is_odd(self) -> Bool {
        ret self & Self::one() != Self::zero()
    }
}

sup [cmp w: U32, cmp signed: Bool] SizedInteger[w, signed] {
    !public
    !inline
    fun bit_shl_checked(self, that: U32) -> Opt[Self] {
        case that >= w { ret None }
        ret Some(val=intrinsics::bit_shl(self, that))
    }

    !public
    !inline
    fun bit_shl_overflow(self, that: U32) -> (Self, Bool) {
        ret (self.bit_shl_wrapping(that), that >= w)
    }

    !public
    !inline
    fun bit_shl_wrapping(self, that: U32) -> Self {
        ret intrinsics::bit_shl(self, that & (w - 1_u32))
    }

    !public
    !inline
    fun bit_shr_checked(self, that: U32) -> Opt[Self] {
        case that >= w { ret None }
        ret Some(val=intrinsics::bit_shr(self, that))
    }

    !public
    !inline
    fun bit_shr_overflow(self, that: U32) -> (Self, Bool) {
        ret (self.bit_shr_wrapping(that), that >= w)
    }

    !public
    !inline
    fun bit_shr_wrapping(self, that: U32) -> Self {
        ret intrinsics::bit_shr(self, that & (w - 1_u32))
    }
}

sup [cmp w: U32, cmp signed: Bool] SizedInteger[w, signed] {
    !public
    !inline
    !intrinsic(name="std.num.sized_integer.zero")
    fun zero() -> Self { }

    !public
    !inline
    !intrinsic(name="std.num.sized_integer.one")
    fun one() -> Self { }

    !public
    !inline
    !intrinsic(name="std.num.sized_integer.two")
    fun two() -> Self { }
}

sup [cmp w: U32, cmp signed: Bool] SizedInteger[w, signed] {
    !public
    !inline
    fun ilog(self, base: Self) -> U32 {
        case self.ilog_checked(base) is Some[U32](val) { ret val }
        abort("ilog: base must be a positive integer")
    }

    !public
    !inline
    fun ilog2(self) -> U32 {
        case self.ilog2_checked() is Some[U32](val) { ret val }
        abort("ilog2: base must be a positive integer")
    }

    !public
    !inline
    fun ilog10(self) -> U32 {
        case self.ilog10_checked() is Some[U32](val) { ret val }
        abort("ilog10: base must be a positive integer")
    }

    !public
    !inline
    fun ilog_checked(self, base: Self) -> Opt[U32] {
        # Todo: self <= 0 or base <= 1 should return None.
        # Todo: cant use ord on this base type, so do bit checking.
        ret Some(val=self.ilog2_checked()? / base.ilog2_checked()?)
    }

    !public
    !inline
    fun ilog2_checked(self) -> Opt[U32] {
        # Todo: self <= 0 should return None.
        # Todo: cant use ord on this base type, so do bit checking.
        ret Some(val=w - 1_u32 - intrinsics::ctlz(self))
    }

    !public
    !inline
    fun ilog10_checked(self) -> Opt[U32] {
        # Todo: self <= 0 or base <= 1 should return None.
        # Todo: cant use ord on this base type, so do bit checking.
        # Todo: no clue if this is right, probably not.
        case self.ilog2_checked() of {
            is Some[U32](val as i) { ret Some(val=log_10_lookup_table.index_ref(U64::from(i))@) }
        }
        ret None()
    }
}
