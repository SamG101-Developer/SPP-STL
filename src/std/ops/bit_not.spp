use std::annotations::abstract_method
use std::annotations::public
use std::void::Void

!public cls BitNot[Ret=Self] { }
!public cls BitNotAssign { }

# Allow the use of the ??? operator.
sup [Ret] BitNot[Ret] {
    !public
    !abstract_method
    fun bit_not(self) -> Ret { }
}

# Allow the use of the ??? operator.
sup BitNotAssign {
    !public
    !abstract_method
    fun bit_not_assign(&mut self) -> Void { }
}
