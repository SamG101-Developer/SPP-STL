use std::annotations::abstract_method
use std::annotations::no_init
use std::annotations::public
use std::void::Void

!public !no_init
cls BitNot[Ret=Self] { }

!public !no_init
cls BitNotAssign { }

sup [Ret] BitNot[Ret] {
    !public
    !abstract_method
    fun bit_not(self) -> Ret { }
}

sup BitNotAssign {
    !public
    !abstract_method
    fun bit_not_assign(&mut self) -> Void { }
}
