use std::annotations::abstract_method
use std::annotations::no_init
use std::annotations::public
use std::annotations::virtual_method
use std::generator::GenOnce
use std::iterator::Indexed
use std::view::View
use std::num::bases::One
use std::num::bases::Zero

!public !no_init
cls IndexMut[T, I] { }

!public !no_init
cls IndexRef[T, I] { }

!public !no_init
cls SliceRef[V, I: Zero] { }

!public !no_init
cls SliceMut[V, I: Zero] { }

sup [T, I] IndexMut[T, I] {
    !public
    !abstract_method
    cor index_mut(&mut self, index: I) -> Indexed[&mut T] { }
}

sup [T, I] IndexRef[T, I] {
    !public
    !abstract_method
    cor index_ref(&self, index: I) -> Indexed[&T] { }
}

sup [V, I: Zero] SliceMut[V, I] {
    !public
    !abstract_method
    fun slice_mut_max_len(&self) -> I { }

    !public
    !abstract_method
    cor slice_mut(&mut self, from: I, into: I) -> GenOnce[&mut V] { }

    !public
    !virtual_method
    cor slice_mut_from(&mut self, from: I) -> GenOnce[&mut V] {
        gen self.slice_mut(from, self.slice_mut_max_len())
    }

    !public
    !virtual_method
    cor slice_mut_to(&mut self, into: I) -> GenOnce[&mut V] {
        gen self.slice_mut(I::zero(), into)
    }

    !public
    !virtual_method
    cor slice_mut_full(&mut self) -> GenOnce[&mut V] {
        gen self.slice_mut(I::zero(), self.slice_mut_max_len())
    }
}

sup [V, I: Zero] SliceRef[V, I] {
    !public
    !abstract_method
    fun slice_ref_max_len(&self) -> I { }

    !public
    !abstract_method
    cor slice_ref(&self, from: I, into: I) -> GenOnce[&V] { }

    !public
    !virtual_method
    cor slice_ref_from(&self, from: I) -> GenOnce[&V] {
        gen self.slice_ref(from, self.slice_ref_max_len())
    }

    !public
    !virtual_method
    cor slice_ref_to(&self, into: I) -> GenOnce[&V] {
        gen self.slice_ref(I::zero(), into)
    }

    !public
    !virtual_method
    cor slice_ref_full(&self) -> GenOnce[&V] {
        gen self.slice_ref(I::zero(), self.slice_ref_max_len())
    }
}
