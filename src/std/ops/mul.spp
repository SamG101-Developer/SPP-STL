use std::annotations::abstract_method
use std::annotations::no_init
use std::annotations::public
use std::void::Void

!public !no_init
cls Mul[Rhs=Self, Ret=Self] { }

!public !no_init
cls MulAssign[Rhs=Self] { }

sup [Rhs, Ret] Mul[Rhs, Ret] {
    !public
    !abstract_method
    fun mul(self, that: Rhs) -> Ret { }
}

sup [Rhs] MulAssign[Rhs] {
    !public
    !abstract_method
    fun mul_assign(&mut self, that: Rhs) -> Void { }
}
