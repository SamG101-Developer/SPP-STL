use std::annotations::abstract_method
use std::annotations::public
use std::void::Void

!public cls Mul[Rhs=Self, Ret=Self] { }
!public cls MulAssign[Rhs=Self] { }

# Allow the use of the "*" operator.
sup [Rhs, Ret] Mul[Rhs, Ret] {
    !public
    !abstract_method
    fun mul(self, that: Rhs) -> Ret { }
}

# Allow the use of the "*=" operator.
sup [Rhs] MulAssign[Rhs] {
    !public
    !abstract_method
    fun mul_assign(&mut self, that: Rhs) -> Void { }
}
