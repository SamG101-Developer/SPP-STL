use std::annotations::abstract_method
use std::annotations::no_init
use std::annotations::public
use std::generator::GenOnce

!public !no_init
cls FwdMut[T] { }

!public !no_init
cls FwdRef[T] { }

sup [T] FwdMut[T] {
    !public
    !abstract_method
    cor fwd_mut(&mut self) -> GenOnce[&mut T] { }
}

sup [T] FwdRef[T] {
    !public
    !abstract_method
    cor fwd_ref(&self) -> GenOnce[&T] { }
}
