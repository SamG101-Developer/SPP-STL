use std::annotations::abstract_method
use std::annotations::public
use std::void::Void

!public cls Pow[Rhs=Self, Ret=Self] { }
!public cls PowAssign[Rhs=Self] { }

# Allow the use of the "**" operator.
sup [Rhs, Ret] Pow[Rhs, Ret] {
    !public
    !abstract_method
    fun pow(self, that: Rhs) -> Ret { }
}

# Allow the use of the "**=" operator.
sup [Rhs] PowAssign[Rhs] {
    !public
    !abstract_method
    fun pow_assign(&mut self, that: Rhs) -> Void { }
}
