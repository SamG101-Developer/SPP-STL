use std::annotations::abstract_method
use std::annotations::no_init
use std::annotations::public
use std::void::Void

!public !no_init
cls Rem[Rhs=Self, Ret=Self] { }

!public !no_init
cls RemAssign[Rhs=Self] { }

sup [Rhs, Ret] Rem[Rhs, Ret] {
    !public
    !abstract_method
    fun rem(self, that: Rhs) -> Ret { }
}

sup [Rhs] RemAssign[Rhs] {
    !public
    !abstract_method
    fun rem_assign(&mut self, that: Rhs) -> Void { }
}
