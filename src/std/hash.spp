##
use std::annotations::abstract_method
use std::annotations::public
use std::number::U8
use std::number::U64
use std::string::Str


cls Hasher { }

sup Hasher {
    !public
    !abstract_method
    fun write(&mut self, bytes: &Slice[U8]) -> Void { }

    !public
    !abstract_method
    fun finish(&self) -> U64 { }
}


cls Hash {}

sup Hash {
    !public
    !abstract_method
    fun hash[H: Hasher](&self, state: &mut H) -> Void { }
}
##
