use std::number::U8
use std::number::USize
use std::option::Opt
use std::option::Some
use std::slice::Slice
use std::string::Str
use std::string_view::StrView


!public
fun print(value: StrView) -> Opt[USize] {
    let slice = Slice[U8]::from(value)
    ret std::console::stdout_stream::stdout.write_all(slice).ok()
}


!public
fun input() -> Opt[Str] {
    let data = std::console::stdin_stream::stdin.read_all().ok()?
    ret Some(val=Str(data))
}
