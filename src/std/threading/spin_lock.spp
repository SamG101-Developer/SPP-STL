use std::annotations::public
use std::annotations::private
use std::annotations::versioned
use std::boolean::Bool
use std::number::U64
use std::result::Fail
use std::result::Pass
use std::result::Res
use std::void::Void
use std::threading::thread::ThreadErr

!public
!versioned(base="1.0.0", new="1.0.0")
cls SpinLock {
    # The `SpinLock` type is a low-level synchronization primitive that provides mutual exclusion for concurrent
    # threads. It is implemented using a busy-waiting mechanism, where a thread repeatedly checks if the lock is
    # available and acquires it when it becomes free. This type is useful in scenarios where the expected wait time for
    # acquiring the lock is short, as it avoids the overhead of context switching associated with traditional mutexes.
    # @let handle: A unique identifier for the spin lock, represented as a 64-bit unsigned integer.

    !private handle: U64
}

sup SpinLock {
    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun new() -> Res[SpinLock, ThreadErr] {
        # Create a new spin lock using the sppc threading API.
        let handle = 0_u64
        sppc::pthread_spin_init(&mut handle)
        ret Pass(val=SpinLock(handle))
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun lock(&self) -> Res[Void, ThreadErr] {
        # Acquire the spin lock using the sppc threading API.
        let err = sppc::pthread__lock(self.id)
        case err != 0 { ret Fail(err=ThreadErr::from_errno(err))  }
        ret Pass[Void]()
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun try_lock(&self) -> Res[Void, ThreadErr] {
        # Try to acquire the spin lock using the sppc threading API.
        let err = sppc::pthread_spin_try_lock(self.id)
        case err != 0 { ret Fail(err=ThreadErr::from_errno(err))  }
        ret Pass[Void]()
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun try_lock(&self) -> Res[Bool, ThreadErr] {
        # Try to acquire the spin lock using the sppc threading API.
        let err = sppc::pthread_spin_try_lock(self.id)
        case err < 0 { ret Fail(err=ThreadErr::from_errno(err))  }
        ret Pass(val=err == 0)
    }

    !public
    !versioned(base="1.0.0", new="1.0.0")
    fun unlock(&self) -> Res[Void, ThreadErr] {
        # Release the spin lock using the sppc threading API.
        let err = sppc::pthread_spin_unlock(self.id)
        case err == 0 { ret Fail(err=ThreadErr::from_errno(err))  }
        ret Pass[Void]()
    }
}
